{
  "manifest_version": 3,
  "name": "Brauo - Read Aloud",
  "version": "0.2.0",
  "description": "Point at any paragraph, click, and listen. Natural text to speech for any page, with Brauo Cloud voices or your own Deepgram key.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.deepgram.com/*", "https://api.brauo.com/*"],
  "background": { "service_worker": "background.js" },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared.js", "voices.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
